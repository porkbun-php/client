{
    "name": "ilyaglebov/porkbun-php-api",
    "description": "PHP client for the Porkbun API",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "porkbun",
        "api",
        "dns",
        "domain",
        "ssl"
    ],
    "authors": [
        {
            "name": "Ilya Glebov",
            "email": "hi@ilyaglebov.dev"
        }
    ],
    "require": {
        "php": "^8.4",
        "nyholm/psr7": "^1.8",
        "php-http/discovery": "^1.19",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.45",
        "guzzlehttp/guzzle": "^7.9",
        "guzzlehttp/psr7": "^2.7",
        "illuminate/support": "^11.0 || ^12.0",
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^3.7",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Porkbun\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Porkbun\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "aliases": {
                "Porkbun": "Porkbun\\Laravel\\Facades\\Porkbun"
            },
            "providers": [
                "Porkbun\\Laravel\\PorkbunServiceProvider"
            ]
        }
    },
    "scripts": {
        "check": [
            "@normalize",
            "@pint",
            "@phpstan",
            "@rector",
            "@test"
        ],
        "fix": [
            "@normalize:fix",
            "@pint:fix",
            "@rector:fix"
        ],
        "normalize": "composer normalize --dry-run",
        "normalize:fix": "composer normalize",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "pint": "pint --test",
        "pint:fix": "pint",
        "rector": "vendor/bin/rector process --dry-run",
        "rector:fix": "vendor/bin/rector process",
        "test": "pest",
        "test:coverage": "pest --coverage"
    }
}
