{
    "name": "ilyaglebov/porkbun-php-api",
    "description": "PHP client for the Porkbun API",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Ilya Glebov",
            "email": "hi@ilyaglebov.dev"
        }
    ],
    "require": {
        "php": "^8.0",
        "nyholm/psr7": "^1.8",
        "php-http/client-common": "^2.7",
        "php-http/curl-client": "^2.3",
        "php-http/discovery": "^1.19",
        "php-http/httplug": "^2.4",
        "psr/cache": "^3.0",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.42",
        "guzzlehttp/guzzle": "^7.8",
        "guzzlehttp/psr7": "^2.6",
        "laravel/pint": "^1.24",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^2.34",
        "php-http/guzzle7-adapter": "^1.0",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-deprecation-rules": "^1.1",
        "phpstan/phpstan-strict-rules": "^1.5",
        "rector/rector": "^1.0",
        "symfony/cache": "^6.3"
    },
    "autoload": {
        "psr-4": {
            "Porkbun\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Porkbun\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "sort-packages": true
    },
    "scripts": {
        "check": [
            "@normalize:check",
            "@pint:check",
            "@phpstan",
            "@rector:dry-run",
            "@test"
        ],
        "normalize": "composer normalize",
        "normalize:check": "composer normalize --dry-run",
        "phpstan": "phpstan analyse",
        "pint": "pint",
        "pint:check": "pint --test",
        "rector": "vendor/bin/rector process",
        "rector:dry-run": "vendor/bin/rector process --dry-run",
        "test": "pest",
        "test:coverage": "pest --coverage"
    }
}
